pipeline {

    agent any

    options {
        timestamps()
        ansiColor('xterm')
    }

    environment {
        APP_NAME = "Enterprise CI/CD Platform"
    }

    stages {

        stage('Checkout') {

            steps {
                checkout scm
            }
        }

        stage('Repository Info') {

            steps {

                echo "Repository checked out successfully."

                sh '''
                    pwd
                    ls -la
                '''
            }
        }

        stage('Environment Info') {

    steps {

        sh '''
            java -version
            git --version
            uname -a
        '''
    }

}

    post {

        success {

            echo "Pipeline completed successfully."
        }

        failure {

            echo "Pipeline failed."
        }

        always {

            cleanWs()
        }
    }
}